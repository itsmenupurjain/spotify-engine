# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spotify_discovery
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/spotify_discovery

# AI APIs
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Reddit API (PRAW)
REDDIT_CLIENT_ID=xxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxx
REDDIT_USER_AGENT=spotify-discovery-engine/1.0

# Twitter/X API
TWITTER_BEARER_TOKEN=xxxxxxxxxxxx

# Apify (Twitter fallback)
APIFY_API_TOKEN=xxxxxxxxxxxx

# App Config
APP_ENV=development
APP_DEBUG=true
API_RATE_LIMIT=100
CORS_ORIGINS=http://localhost:3000

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
